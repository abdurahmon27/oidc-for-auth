rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user may only read/write their own profile document, written to
    // by the client once authenticated with the custom token minted by
    // telegramVerify (or another provider).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // telegram_logins holds pending login tokens and salted OTP hashes.
    // It is only ever read/written by the Cloud Functions via the Admin
    // SDK, which bypasses Security Rules entirely -- so no client, even an
    // authenticated one, should be able to touch it.
    match /telegram_logins/{document=**} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
