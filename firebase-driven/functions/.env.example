# Copy to .env (functions/.env) for local emulation, and set the same values
# as function secrets/config for deployment, e.g.:
#   firebase functions:secrets:set TELEGRAM_BOT_TOKEN
#   firebase functions:secrets:set WEBHOOK_SECRET

# BotFather token for the Telegram bot used for OTP login.
TELEGRAM_BOT_TOKEN=

# Random secret used as the trailing path segment of the webhook URL, so
# only requests that know the secret (i.e. Telegram, once we register it)
# are accepted. Generate with e.g. `openssl rand -hex 32`.
WEBHOOK_SECRET=

# After `npm run deploy`, register the webhook with Telegram so it POSTs
# updates to telegramWebhook instead of requiring long-polling:
#   https://api.telegram.org/bot<TOKEN>/setWebhook?url=<functionsBaseUrl>/telegramWebhook/<WEBHOOK_SECRET>
# where <functionsBaseUrl> looks like:
#   https://<region>-<project-id>.cloudfunctions.net
