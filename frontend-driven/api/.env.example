# Database
DATABASE_URL=postgres://authuser:authpass@localhost:5432/authdb?sslmode=disable

# Server
SERVER_PORT=8080
FRONTEND_URL=http://localhost:5173
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# OAuth Provider Client IDs (no secrets needed for OIDC id_token validation)
GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT=common

# Facebook (needs secret for debug_token verification)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# GitHub (needs secret for code exchange)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Telegram: a bot token from @BotFather (format 123456789:ABC...), NOT a
# Gateway API token. The bot delivers the login OTP in-chat. Leave empty to
# disable Telegram login.
TELEGRAM_API_TOKEN=
